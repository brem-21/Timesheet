{
  "manifest_version": 2,
  "name": "Clock-It Activity Tracker",
  "version": "1.0.0",
  "description": "Logs browser activity and extracts Teams meeting transcripts for Clock-It",
  "browser_specific_settings": {
    "gecko": {
      "id": "clockit-tracker@amalitech",
      "strict_min_version": "91.0"
    }
  },
  "permissions": [
    "tabs",
    "storage"
  ],
  "content_scripts": [
    {
      "matches": ["*://teams.microsoft.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Clock-It Tracker"
  }
}
